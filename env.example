# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file — it's excluded via .gitignore.
#
# This project runs against Neo4j Aura (cloud) only — no local Neo4j
# Desktop/Community install is used or supported here.
# NEO4J_URI must be your Aura connection URI, e.g.:
#   neo4j+s://<your-db-id>.databases.neo4j.io
# Get an Aura instance: https://console.neo4j.io  (free tier available —
# verify current size limits in the console before relying on published
# numbers, they've been inconsistent across Neo4j's own docs)
#
# If you're on a network that does TLS/SSL inspection (campus WiFi,
# corporate firewall, some antivirus "web protection" features), you may
# hit `SSLCertVerificationError: self-signed certificate in certificate
# chain`. If so, swap the scheme from neo4j+s:// to neo4j+ssc:// — this
# skips certificate chain validation instead of rejecting the connection.
# Trade-off: it stops the driver from being able to detect a real
# man-in-the-middle on that connection, so only use it on a network you
# trust. The official neo4j Python driver only supports these schemes:
# bolt, bolt+ssc, bolt+s, neo4j, neo4j+ssc, neo4j+s (NOT a bare https://).
NEO4J_URI=neo4j+s://<your-db-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=


# --- Agentic LLM providers ---
# Groq is tried first, Mistral is the fallback. Either or both may be left
# blank: the agent layer degrades to deterministic rule-based logic if no
# provider is configured, rather than failing to start.
# Get a Groq key:    https://console.groq.com
# Get a Mistral key: https://console.mistral.ai
GROQ_API_KEY=
MISTRAL_API_KEY=


# --- Tunable constants (all optional — every line below has a sensible
# default in backend/app/config.py and can be left unset). Uncomment and
# change a value only if you actually want to override that default.
# None of these numbers are validated against real usage; see the HONESTY
# NOTE comments in optimizer/decay.py and marketplace/quality.py.

# Adaptive decay model
# DECAY_RATE_PER_DAY=0.03
# DECAY_THRESHOLD=0.5

# Marketplace quality scoring
# QUALITY_WEIGHT_PEER_RATING=0.5
# QUALITY_WEIGHT_RECENCY=0.2
# QUALITY_WEIGHT_COMPLETENESS=0.3
# QUALITY_RECENCY_DECAY_RATE_PER_DAY=0.01

# Marketplace discovery/similarity
# MARKETPLACE_SIMILARITY_THRESHOLD=0.5
# MARKETPLACE_DUPLICATE_THRESHOLD=0.95

# Trust-weighted path ordering
# TRUST_WEIGHTING_EPSILON=0.01
# TRUST_WEIGHTING_MIN_WEIGHT=0.01
# TRUST_WEIGHTING_DISCOUNT_FACTOR=0.5

# Storage backend ('local' or 'cloud' — cloud is not yet implemented)
# STORAGE_BACKEND=local
# LOCAL_STORAGE_DIR=./marketplace_files

# API / CORS — set this to your real frontend origin(s) before exposing
# the API beyond localhost. Comma-separated, or '*' for all origins.
# CORS_ALLOW_ORIGINS=*

# Autonomous background scheduler
# SCHEDULER_ENABLED=true
# DECAY_SCAN_INTERVAL_MINUTES=60
# CALIBRATION_INTERVAL_MINUTES=1440

# LLM call parameters — see app/config.py for the full list (per-call-site
# temperature/max_tokens, request timeout). Uncomment individually if you
# need to override one; most people never will.
# LLM_REQUEST_TIMEOUT_SECONDS=20.0
